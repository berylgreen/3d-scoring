# ==========================================
# 3D 评分系统 (3D Scoring) 环境配置文件示例
# ==========================================

# 大模型配置 (向后兼容旧版环境变量)
# 选择使用的模型提供商协议: "gemini" 或 "openai"
LLM_PROVIDER=gemini

# API 密钥 (Gemini 支持用逗号分隔多个 Key 轮询)
LLM_API_KEYS=your_api_key_1,your_api_key_2

# 模型版本 (例如 gemini-3.1-flash-lite)
LLM_MODEL=gemini-3.1-flash-lite

# 若使用代理服务或 OpenAI 兼容接口，请取消注释并填入地址，例如: http://127.0.0.1:7861
# LLM_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai/
