# ==========================================
# 3D 评分系统 (3D Scoring) 环境配置文件示例
# ==========================================

# 1. 大模型配置 (向后兼容旧版环境变量)
# 选择使用的模型提供商协议: "gemini" 或 "openai"
LLM_PROVIDER=openai
# API 密钥 (Gemini 支持用逗号分隔多个 Key 轮询)
LLM_API_KEYS=your_api_key_here
# 模型版本 (例如 gemini-2.5-flash)
LLM_MODEL=gemini-3.5-flash
# 若使用代理服务或 OpenAI 兼容接口，请填入地址，例如: http://127.0.0.1:7861
LLM_API_BASE=https://api.example.com/v1

# 2. 课程与模式配置
# 课程类型，可选值: animation (三维动画) 或 modeling (三维建模)
COURSE_TYPE=animation

# 打分模式，可选值: individual (个人评分) 或 group (小组评分)
GRADING_MODE=individual

# 3. 数据存放路径
# 默认为项目根目录下的 data 文件夹，您可以填绝对路径如 "Z:\学生文件\考试学生答卷\2025-2026上\计算机三维动画设计提高" 
# 来直接复用老项目里的学生数据
DATA_DIR=data

# 4. 其他开关
ENABLE_LLM_GRADING=true
